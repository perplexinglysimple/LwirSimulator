.processor {
  width 4

  hardware {
    unit alu = integer_alu
    unit mem = memory
    unit ctrl = control
    unit mul = multiplier
  }

  layout slots {
    0 = { alu }
    1 = { alu }
    2 = { mem }
    3 = { ctrl, mul }
  }

  cache { }
  topology { cpus 1 }
}
# Illegal: same-bundle RAW hazard (I1 reads r1 written by I0 in same bundle).
{
  i0: movi r1, 42
  i1: add r2, r1, r0
  m : nop
  x : ret
}
