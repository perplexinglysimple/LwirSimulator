# expected-rule: slot-opcode-legality
.processor {
  width 4

  hardware {
    unit alu = integer_alu
    unit mem = memory
    unit ctrl = control
    unit mul = multiplier
  }

  layout slots {
    0 = { alu }
    1 = { alu }
    2 = { mem }
    3 = { ctrl, mul }
  }

  cache { }
  topology { cpus 1 }
}
# Illegal: store_d is a Memory-class op but is placed in I0.
{
  i0: std [r0 + 0x100], r1
  i1: nop
  m : nop
  x : ret
}
