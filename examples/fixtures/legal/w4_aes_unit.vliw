.processor {
  width 4

  hardware {
    unit alu = integer_alu
    unit mem = memory
    unit ctrl = control
    unit mul = multiplier
    unit aes = aes { variant aes_ni latency 4 }
  }

  layout slots {
    0 = { alu }
    1 = { alu }
    2 = { mem }
    3 = { aes, ctrl, mul }
  }

  cache { }
  topology { cpus 1 }
}

entry:
{
  i0: movi r1, 10
  i1: movi r2, 32
  m : nop
  x : nop
}

{
  i0: nop
  i1: nop
  m : nop
  x : aesenc r3, r1, r2
}

{
  i0: nop
  i1: nop
  m : nop
  x : ret
}
