.processor {
  width 4

  hardware {
    unit alu = integer_alu
    unit mem = memory
    unit ctrl = control
    unit mul = multiplier
  }

  layout slots {
    0 = { alu }
    1 = { alu }
    2 = { mem }
    3 = { ctrl, mul }
  }

  cache { }
  topology { cpus 2 }
}

{
  i0: nop
  i1: nop
  m : nop
  x : nop
}

{
  i0: nop
  i1: nop
  m : relstore r0, r0, 0
  x : nop
}

{
  i0: nop
  i1: nop
  m : nop
  x : ret
}
