# expected-rule: slot-opcode-legality
.processor {
  width 4

  hardware {
    unit alu = integer_alu
    unit mem = memory
    unit ctrl = control
    unit mul = multiplier
  }

  layout slots {
    0 = { alu }
    1 = { alu }
    2 = { mem }
    3 = { ctrl, mul }
  }

  cache { }
  topology { cpus 1 }
}

entry:
{
  i0: movi r1, 10
  i1: movi r2, 32
  m : nop
  x : fpadd64 r3, r1, r2
}
